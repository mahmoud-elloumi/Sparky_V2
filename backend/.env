# ============================================================
# SPARKY Backend - Environment Variables
# ============================================================

# Server
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=sparky-dev-secret-key-2026

# PostgreSQL (désactivé pour dev sans DB)
DATABASE_URL=postgresql+asyncpg://sparky:sparky_pass@127.0.0.1:5432/sparky_db

# Supabase (vide = mode local)
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_BUCKET=sparky-documents

# Google Cloud Document AI (vide = mode dégradé regex)
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_PROJECT_ID=
GOOGLE_LOCATION=eu
GOOGLE_PROCESSOR_ID=

# Mistral AI (OCR + extraction intelligente)
MISTRAL_API_KEY=AlSTFcTTm2h5Lkizs3XoXkdiYnDSmZiu
MISTRAL_MODEL=mistral-small-latest
MISTRAL_VISION_MODEL=pixtral-12b-2409

# n8n Webhook
N8N_WEBHOOK_URL=http://localhost:5678/webhook/sparky/notify
N8N_WEBHOOK_SECRET=sparky-secret

# CORS
ALLOWED_ORIGINS=["http://localhost:4200","http://localhost:3000"]
