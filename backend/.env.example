# ============================================================
# SPARKY Backend - Environment Variables
# ============================================================

# Server
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=your-super-secret-key-change-in-production

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://sparky:sparky_pass@localhost:5432/sparky_db

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_BUCKET=sparky-documents

# Google Cloud Document AI
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GOOGLE_PROJECT_ID=your-gcp-project-id
GOOGLE_LOCATION=eu
GOOGLE_PROCESSOR_ID=your-document-ai-processor-id

# n8n Webhook
N8N_WEBHOOK_URL=http://localhost:5678/webhook/sparky
N8N_WEBHOOK_SECRET=your-n8n-webhook-secret

# CORS
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000
